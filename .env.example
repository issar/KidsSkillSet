VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# DEV/STAGING ONLY: Set to true for local dev to skip email verification.
# Supabase must have "Confirm email" OFF (Authentication → Email).
# PRODUCTION: Must be false or omitted. Never deploy with this true.
VITE_AUTO_VERIFY_EMAIL=false
